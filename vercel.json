{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm --prefix apps/frontend run build",
  "outputDirectory": "apps/frontend/dist",
  "env": {
    "VITE_API_URL": "https://budgetmind-api.onrender.com/api"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
